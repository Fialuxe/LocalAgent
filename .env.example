# LocalAgent — APIキー設定テンプレート
# このファイルを .env にコピーして値を埋めてください
# cp .env.example .env

# ── NewsAPI.org（日本・韓国ニュース）──────────────────────────────────────
# 無料プラン: 100リクエスト/日
# 登録: https://newsapi.org/register
NEWSAPI_KEY=

# ── Naver Open API（韓国語ニュース）──────────────────────────────────────
# 無料。登録: https://developers.naver.com/apps/#/register
# → 「검색」(検索) API にチェックを入れる
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
